{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2022", "DOM"],
        "strict": true,
        "noUnusedLocals": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "types": ["@playwright/test", "node"]
    },
    "include": ["specs/**/*.ts", "fixtures/**/*.ts"]
}
